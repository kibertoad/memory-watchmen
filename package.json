{
  "name": "memory-watchmen",
  "version": "1.0.0",
  "description": "Memory and event loop testing for Node.js — heap monitoring, event loop delay and utilization tracking, object lifecycle verification, stream buffer assertions, and comparative profiling",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vitest": {
      "import": "./dist/vitest.js",
      "types": "./dist/vitest.d.ts"
    },
    "./profiler": {
      "import": "./dist/profiler/server.js",
      "types": "./dist/profiler/server.d.ts"
    },
    "./profiler/runner": {
      "import": "./dist/profiler/runner.js",
      "types": "./dist/profiler/runner.d.ts"
    },
    "./profiler/chart": {
      "import": "./dist/profiler/chart.js",
      "types": "./dist/profiler/chart.d.ts"
    }
  },
  "bin": {
    "memory-watchmen": "./dist/bin/memory-watchmen.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:memory": "vitest run --config vitest.memory.config.ts",
    "lint": "oxlint && tsc --noEmit -p tsconfig.check.json",
    "lint:fix": "oxlint --fix",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "memory",
    "leak",
    "detection",
    "heap",
    "gc",
    "event-loop",
    "starvation",
    "latency",
    "utilization",
    "delay",
    "perf_hooks",
    "streams",
    "backpressure",
    "profiler",
    "testing",
    "performance",
    "monitoring"
  ],
  "author": "Igor Savin",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
